{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "https://via.placeholder.com/80",
              "size": "Medium",
              "style": "Person"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "John Doe",
              "weight": "Bolder",
              "size": "Large"
            },
            {
              "type": "TextBlock",
              "text": "Senior Software Engineer",
              "spacing": "None",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "text": "Engineering Department",
              "spacing": "None",
              "isSubtle": true
            }
          ]
        }
      ]
    },
    {
      "type": "FactSet",
      "spacing": "Medium",
      "separator": true,
      "facts": [
        {
          "title": "Email:",
          "value": "john.doe@company.com"
        },
        {
          "title": "Phone:",
          "value": "+1 (555) 123-4567"
        },
        {
          "title": "Location:",
          "value": "New York, NY"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Send Email",
      "url": "mailto:john.doe@company.com"
    },
    {
      "type": "Action.OpenUrl",
      "title": "View Profile",
      "url": "https://example.com/profile/johndoe"
    }
  ]
}
