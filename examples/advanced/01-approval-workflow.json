{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://via.placeholder.com/50",
                  "size": "Small",
                  "style": "Person"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Purchase Order Approval Required",
                  "weight": "Bolder",
                  "size": "Large"
                },
                {
                  "type": "TextBlock",
                  "text": "PO-2024-0156",
                  "spacing": "None",
                  "isSubtle": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "🟡 Pending",
                  "color": "Warning",
                  "weight": "Bolder"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Request Details",
          "weight": "Bolder",
          "size": "Medium"
        },
        {
          "type": "FactSet",
          "spacing": "Small",
          "facts": [
            {
              "title": "Requested by:",
              "value": "John Smith (Engineering)"
            },
            {
              "title": "Date submitted:",
              "value": "January 15, 2024"
            },
            {
              "title": "Total amount:",
              "value": "$12,450.00"
            },
            {
              "title": "Budget code:",
              "value": "ENG-2024-Q1-CAPEX"
            },
            {
              "title": "Vendor:",
              "value": "TechSupply Corporation"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Items",
          "weight": "Bolder"
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "MacBook Pro 16\" (M3 Max)",
                  "weight": "Bolder"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Qty: 3",
                  "isSubtle": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "$8,997.00"
                }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "USB-C Hub & Adapters"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Qty: 3",
                  "isSubtle": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "$450.00"
                }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "External 4K Monitor"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Qty: 3",
                  "isSubtle": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "$2,697.00"
                }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Shipping & Handling"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": ""
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "$306.00"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Business Justification",
          "weight": "Bolder"
        },
        {
          "type": "TextBlock",
          "text": "Equipment for three new senior developers joining the AI Research team. Current project pipeline requires increased team capacity. Expected ROI through accelerated project delivery and improved developer productivity.",
          "wrap": true,
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Approval History",
          "weight": "Bolder"
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "✅",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Sarah Chen (Team Lead) - Approved",
                  "weight": "Bolder"
                },
                {
                  "type": "TextBlock",
                  "text": "\"Approved for new team members. Critical for project timeline.\"",
                  "spacing": "None",
                  "isSubtle": true,
                  "wrap": true
                },
                {
                  "type": "TextBlock",
                  "text": "Jan 15, 2024 10:30 AM",
                  "spacing": "None",
                  "size": "Small",
                  "isSubtle": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Your Decision",
          "weight": "Bolder"
        },
        {
          "type": "Input.ChoiceSet",
          "id": "approvalDecision",
          "style": "expanded",
          "isRequired": true,
          "choices": [
            {
              "title": "✅ Approve - Proceed with purchase",
              "value": "approved"
            },
            {
              "title": "❌ Reject - Do not proceed",
              "value": "rejected"
            },
            {
              "title": "⏸️ Request More Information",
              "value": "moreinfo"
            }
          ]
        },
        {
          "type": "Input.Text",
          "id": "approverComments",
          "label": "Comments",
          "placeholder": "Add your comments or feedback...",
          "isMultiline": true
        },
        {
          "type": "Input.Toggle",
          "id": "notifyRequester",
          "title": "Notify requester of decision",
          "value": "true"
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Small",
      "items": [
        {
          "type": "TextBlock",
          "text": "⚠️ This action requires your approval authority for purchases over $10,000.",
          "wrap": true,
          "size": "Small",
          "color": "Warning"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "✅ Approve",
      "style": "positive",
      "data": {
        "actionType": "approvalDecision",
        "poNumber": "PO-2024-0156",
        "decision": "approved"
      }
    },
    {
      "type": "Action.Submit",
      "title": "❌ Reject",
      "style": "destructive",
      "data": {
        "actionType": "approvalDecision",
        "poNumber": "PO-2024-0156",
        "decision": "rejected"
      }
    },
    {
      "type": "Action.ShowCard",
      "title": "📄 View Attachments",
      "card": {
        "type": "AdaptiveCard",
        "body": [
          {
            "type": "TextBlock",
            "text": "Attached Documents",
            "weight": "Bolder"
          },
          {
            "type": "TextBlock",
            "text": "📎 Quote_TechSupply_2024.pdf",
            "spacing": "Small"
          },
          {
            "type": "TextBlock",
            "text": "📎 Budget_Approval_Form.pdf",
            "spacing": "Small"
          },
          {
            "type": "TextBlock",
            "text": "📎 Vendor_Agreement.pdf",
            "spacing": "Small"
          }
        ],
        "actions": [
          {
            "type": "Action.OpenUrl",
            "title": "Download All",
            "url": "https://example.com/po/PO-2024-0156/attachments"
          }
        ]
      }
    },
    {
      "type": "Action.OpenUrl",
      "title": "View in Portal",
      "url": "https://example.com/approvals/PO-2024-0156"
    }
  ]
}
